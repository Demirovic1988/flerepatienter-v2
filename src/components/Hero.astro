---
const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';
---

<section
  id="start-her"
  class="relative bg-paper pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden"
>
  <!-- Diskret baggrundsdetalje (jordnær, varm) -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 right-0 w-[640px] h-[640px] rounded-full bg-cream/60 blur-3xl translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[420px] h-[420px] rounded-full bg-bone blur-3xl -translate-x-1/4 translate-y-1/3"></div>
  </div>

  <div class="max-w-6xl mx-auto px-5 relative z-10">
    <div class="max-w-3xl">

      <!-- 1. Eyebrow / kategori -->
      <p class="reveal eyebrow mb-6">Marketing for tandklinikker</p>

      <!-- 2. Hovedoverskrift (kursiv + orange aftryksfangst) -->
      <h1 class="reveal reveal-delay-1 text-[44px] sm:text-6xl md:text-7xl font-medium mb-6 tracking-tight">
        Vi finder <span class="accent">hullerne</span><br />
        i din markedsføring.
      </h1>

      <!-- 3. Underrubrik — konkret bevis -->
      <p class="reveal reveal-delay-2 text-lg md:text-xl text-ash leading-relaxed mb-10 max-w-2xl">
        Tandklinikker mister i snit <strong class="text-ink font-semibold">38&nbsp;%</strong> af
        deres kvalificerede leads — ikke fordi marketingen er dårlig, men fordi der er
        huller mellem klik og booking. Vi finder dem på 30&nbsp;minutter.
      </p>

      <!-- 4. CTA + 5. Mikro-tillid -->
      <div class="reveal reveal-delay-3 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
        <a
          href={CALENDLY}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary text-base px-7 py-4"
        >
          Book gratis strategisamtale
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <p class="text-sm text-ash flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="#6B6B6B" stroke-width="1.2"/>
            <path d="M8 4v4l2.5 1.5" stroke="#6B6B6B" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          Ingen binding · 30 min · gratis
        </p>
      </div>

    </div>
  </div>
</section>
