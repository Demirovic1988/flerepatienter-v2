---
const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';
---

<section id="kontakt" class="py-24 bg-navy relative overflow-hidden">

  <!-- Background decoration -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-[#F97316]/10 blur-3xl translate-x-1/3 -translate-y-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full bg-white/5 blur-3xl -translate-x-1/4 translate-y-1/4"></div>
  </div>

  <div class="max-w-6xl mx-auto px-5 relative z-10">

    <!-- Headline -->
    <div class="text-center mb-14">
      <h2 class="reveal text-4xl md:text-5xl font-extrabold text-white mb-4">
        Klar til at få flere patienter?
      </h2>
      <p class="reveal reveal-delay-1 text-white/60 text-lg max-w-xl mx-auto">
        Book en gratis og uforpligtende samtale. Vi gennemgår din klinik og
        fortæller dig præcist, hvad vi ville gøre.
      </p>
    </div>

    <!-- Contact cards -->
    <div class="reveal reveal-delay-1 grid sm:grid-cols-2 gap-5 max-w-xl mx-auto mb-12">

      <a
        href="tel:+4581530540"
        class="group flex items-center gap-4 bg-white/8 hover:bg-white/14 border border-white/10 hover:border-[#F97316]/40 rounded-2xl px-6 py-5 transition-all duration-200"
        aria-label="Ring til +45 81 530 540"
      >
        <div class="w-11 h-11 rounded-xl bg-[#F97316]/20 flex items-center justify-center shrink-0 group-hover:bg-[#F97316]/35 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.12 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 5.72 5.72l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <div>
          <div class="text-white/50 text-xs font-medium mb-0.5">Telefon</div>
          <div class="text-white font-semibold text-[15px]">+45 81 530 540</div>
        </div>
      </a>

      <a
        href="mailto:jatak@flerepatienter.dk"
        class="group flex items-center gap-4 bg-white/8 hover:bg-white/14 border border-white/10 hover:border-[#F97316]/40 rounded-2xl px-6 py-5 transition-all duration-200"
        aria-label="Send email til jatak@flerepatienter.dk"
      >
        <div class="w-11 h-11 rounded-xl bg-[#F97316]/20 flex items-center justify-center shrink-0 group-hover:bg-[#F97316]/35 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <div>
          <div class="text-white/50 text-xs font-medium mb-0.5">Email</div>
          <div class="text-white font-semibold text-[15px]">jatak@flerepatienter.dk</div>
        </div>
      </a>

    </div>

    <!-- Main CTA -->
    <div class="reveal reveal-delay-2 text-center">
      <a
        href={CALENDLY}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-teal hover:bg-teal-dark text-white font-bold text-lg px-10 py-5 rounded-full transition-all duration-200 shadow-xl shadow-[#F97316]/20 hover:shadow-[#F97316]/40 hover:-translate-y-0.5"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Book gratis samtale – helt uforpligtende
      </a>
      <p class="mt-4 text-white/40 text-sm">Svar inden for 24 timer · Ingen binding</p>
    </div>

  </div>
</section>
