---
const year = new Date().getFullYear();
---

<footer class="bg-[#111827] text-white/50 py-10">
  <div class="max-w-6xl mx-auto px-5 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">

    <!-- Logo -->
    <a href="/" aria-label="Flerepatienter.dk – hjem" class="flex items-center gap-2 text-white hover:text-teal transition-colors">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="8" fill="#0EA5A0"/>
        <path d="M10 16h12M16 10v12" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
      <span class="font-bold">Flerepatienter.dk</span>
    </a>

    <!-- Links -->
    <nav aria-label="Footer navigation" class="flex items-center gap-6">
      <a href="/privatlivspolitik" class="hover:text-white transition-colors">
        Privatlivs- og Cookiepolitik
      </a>
    </nav>

    <!-- Copyright -->
    <p>© {year} Flerepatienter.dk</p>

  </div>
</footer>
