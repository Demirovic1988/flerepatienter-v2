---
const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';

const navLinks = [
  { label: 'Hullerne',    href: '#de-skjulte-huller' },
  { label: 'Sådan virker det', href: '#saadan' },
  { label: 'Elvis',       href: '#moed-elvis' },
  { label: 'Cases',       href: '#cases' },
  { label: 'Guides',      href: '/guides/' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-5 flex items-center justify-between h-16 md:h-[72px]">

    <!-- Wordmark (CSS-renderet jf. brandbook §02) -->
    <a href="/" aria-label="Flerepatienter.dk – forside" class="shrink-0 wordmark text-[22px] md:text-[24px]">
      <span>Flere</span><span class="it">patienter</span><span>.dk</span>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primær navigation" class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-ash hover:text-orange transition-colors duration-200"
          style="font-family: var(--font-sans);"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex btn btn-primary text-sm py-[10px] px-5"
    >
      Book strategisamtale
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Hamburger -->
    <button
      id="menu-btn"
      aria-label="Åbn menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden p-2 rounded text-ink"
    >
      <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" class="hidden" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-line px-5 py-5 flex-col gap-1 shadow-sm"
    aria-label="Mobil navigation"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link text-base font-medium text-ink py-2 hover:text-orange transition-colors"
        style="font-family: var(--font-sans);"
      >
        {link.label}
      </a>
    ))}
    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 btn btn-primary"
    >
      Book strategisamtale
    </a>
  </div>
</header>

<script>
  const header    = document.getElementById('site-header')!;
  const btn       = document.getElementById('menu-btn')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Sticky baggrund — kun når der scrolles
  window.addEventListener('scroll', () => {
    if (window.scrollY > 8) {
      header.classList.add('bg-paper/95', 'backdrop-blur-md', 'border-b', 'border-line');
    } else {
      header.classList.remove('bg-paper/95', 'backdrop-blur-md', 'border-b', 'border-line');
    }
  }, { passive: true });

  // Hamburger toggle
  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false;
    menu.classList.toggle('flex', open);
    btn.setAttribute('aria-expanded', String(open));
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
  });

  // Luk ved klik på link
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      btn.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
