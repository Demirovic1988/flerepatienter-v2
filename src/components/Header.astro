---
const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';

const navLinks = [
  { label: 'Start her',          href: '#start-her' },
  { label: 'De skjulte huller', href: '#de-skjulte-huller' },
  { label: 'Mød Elvis',          href: '#moed-elvis' },
  { label: 'Kontakt',            href: '#kontakt' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-5 flex items-center justify-between h-16 md:h-18">

    <!-- Logo -->
    <a href="/" aria-label="Flerepatienter.dk – hjem" class="shrink-0">
      <img src="/images/logo.webp" alt="Flerepatienter.dk" width="160" height="45" class="h-9 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primær navigation" class="hidden md:flex items-center gap-7">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-[#475569] hover:text-teal transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center gap-2 bg-teal hover:bg-teal-dark text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-colors duration-200 shadow-sm"
    >
      Book gratis samtale
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>

    <!-- Hamburger -->
    <button
      id="menu-btn"
      aria-label="Åbn menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden p-2 rounded-lg text-navy"
    >
      <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" class="hidden" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-gray-100 px-5 py-4 flex-col gap-4 shadow-lg"
    aria-label="Mobil navigation"
  >
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-nav-link text-base font-medium text-navy py-1 hover:text-teal transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href={CALENDLY}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 inline-flex justify-center bg-teal hover:bg-teal-dark text-white font-semibold px-5 py-3 rounded-full transition-colors"
    >
      Book gratis samtale
    </a>
  </div>
</header>

<script>
  const header    = document.getElementById('site-header')!;
  const btn       = document.getElementById('menu-btn')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Sticky shadow
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm');
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm');
    }
  }, { passive: true });

  // Hamburger toggle
  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false;
    menu.classList.toggle('flex', open);
    btn.setAttribute('aria-expanded', String(open));
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
  });

  // Close on nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      btn.setAttribute('aria-expanded', 'false');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
