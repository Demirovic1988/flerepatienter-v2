---
const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';

const bullets = [
  'Specialiseret udelukkende i tandlæger og klinikker',
  'Dokumenterede resultater – ikke bare flotte præsentationer',
  'Transparent kommunikation og løbende rapportering',
  'Du beholder kontrol – ingen binding, ingen overraskelser',
  'Lokalt forankret, digitalt stærk',
];
---

<section id="moed-elvis" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-5">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Foto/placeholder -->
      <div class="reveal order-2 lg:order-1">
        <div class="relative max-w-sm mx-auto lg:mx-0">
          <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl">
            <img
              src="/images/elvis.webp"
              alt="Elvis Demirovic – specialist i tandlæge markedsføring"
              width="1080"
              height="1920"
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
          </div>
          <!-- Decoration -->
          <div aria-hidden="true" class="absolute -bottom-4 -right-4 w-24 h-24 rounded-2xl bg-[#F97316]/15 -z-10"></div>
          <div aria-hidden="true" class="absolute -top-4 -left-4 w-16 h-16 rounded-xl bg-navy/10 -z-10"></div>
        </div>
      </div>

      <!-- Tekst -->
      <div class="order-1 lg:order-2">
        <div class="reveal inline-block bg-[#F97316]/10 text-[#F97316] text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded-full mb-5">
          Mød Elvis
        </div>

        <h2 class="reveal reveal-delay-1 text-4xl md:text-5xl font-extrabold text-navy mb-2">
          Elvis Demirovic
        </h2>
        <p class="reveal reveal-delay-1 text-[#F97316] font-semibold mb-6">
          Tandlæge markedsføring – specialisten
        </p>

        <p class="reveal reveal-delay-2 text-lg text-muted leading-relaxed mb-8">
          Jeg hjælper tandlægeklinikker med at vokse – ikke ved at bruge store ord,
          men ved at levere konkrete resultater. Jeg ved præcist, hvilke knapper der
          skal skubbes til for at en tandlæge tiltrækker nye patienter konsekvent.
        </p>

        <ul class="reveal reveal-delay-2 space-y-3 mb-10" role="list">
          {bullets.map((b) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 shrink-0 w-5 h-5 rounded-full bg-[#F97316]/15 flex items-center justify-center" aria-hidden="true">
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6l3 3 5-5" stroke="#F97316" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="text-[15px] text-text leading-relaxed">{b}</span>
            </li>
          ))}
        </ul>

        <div class="reveal reveal-delay-3 bg-[#FFF7F0] rounded-2xl p-6 border border-[#F97316]/15 mb-8">
          <p class="text-navy font-medium text-[15px] leading-relaxed italic">
            "Jeg arbejder kun med tandlæger. Det er et bevidst valg – fordi det giver mig mulighed
            for at kende branchen bedre end nogen generalist nogensinde vil. 🎯"
          </p>
          <p class="mt-3 text-sm font-semibold text-[#F97316]">– Elvis Demirovic</p>
        </div>

        <a
          href={CALENDLY}
          target="_blank"
          rel="noopener noreferrer"
          class="reveal reveal-delay-3 inline-flex items-center gap-2 bg-navy hover:bg-navy-light text-white font-bold px-8 py-4 rounded-full transition-all duration-200 shadow-md hover:-translate-y-0.5"
        >
          Book en gratis snak med Elvis
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
