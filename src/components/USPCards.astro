---
const cards = [
  {
    num: '01',
    title: 'Diagnose før recept',
    text:
      'Vi anbefaler ikke en løsning før vi har set hullet. Vi kortlægger præcis hvor i patientrejsen klinikken taber penge — fra første visning til booket tid.',
  },
  {
    num: '02',
    title: 'Ingen bindinger, kun resultater',
    text:
      'Vi binder ikke kunder. Vi gør os fortjent til dem hver måned. Ingen lange kontrakter, ingen overraskelser — kun arbejde der flytter tallene.',
  },
  {
    num: '03',
    title: 'Vi taler tandklinik',
    text:
      'Vi arbejder kun med tandklinikker. Vi kender patientrejsen indefra og kan se mønstre andre overser. Ingen generisk marketing — kun det der konverterer.',
  },
];
---

<section id="saadan" class="py-24 md:py-32 bg-white">
  <div class="max-w-6xl mx-auto px-5">

    <!-- Section header -->
    <div class="max-w-2xl mb-14 md:mb-16">
      <p class="reveal eyebrow mb-4">Sådan arbejder vi</p>
      <h2 class="reveal reveal-delay-1 text-4xl md:text-5xl font-medium mb-5 tracking-tight">
        Andre bureauer sælger annoncer.<br />
        Vi sælger <span class="accent">diagnostik.</span>
      </h2>
      <p class="reveal reveal-delay-2 text-lg text-ash leading-relaxed">
        Inden vi foreslår noget som helst, finder vi hullerne. Tre principper
        gennemsyrer alt vi gør.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {cards.map((card, i) => (
        <article class={`reveal reveal-delay-${i + 1} group bg-bone hover:bg-cream/40 border border-line/60 rounded-lg p-8 transition-colors duration-300`}>
          <div class="flex items-baseline gap-3 mb-5">
            <span class="text-3xl text-orange italic" style="font-family: var(--font-display); font-weight: 500;">{card.num}</span>
            <span class="h-px flex-1 bg-line"></span>
          </div>
          <h3 class="text-[22px] font-medium text-ink mb-3 leading-snug" style="font-family: var(--font-display); letter-spacing: -0.01em;">{card.title}</h3>
          <p class="text-ash text-[15px] leading-relaxed">{card.text}</p>
        </article>
      ))}
    </div>

  </div>
</section>
