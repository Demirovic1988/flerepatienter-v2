---
const logos = [
  { src: '/images/logos/WhiteParts-125x70-1.webp',      alt: 'WhiteParts.dk' },
  { src: '/images/logos/AROX-125x70-1.webp',            alt: 'AROX' },
  { src: '/images/logos/CookPerfect-125x70-1.webp',     alt: 'CookPerfect' },
  { src: '/images/logos/ZegoWater-125x70-1.webp',       alt: 'ZegoWater' },
  { src: '/images/logos/Hafniahus-125x70-1.webp',       alt: 'Hafniahus Tandlægerne' },
  { src: '/images/logos/Preloved-125x70-1.webp',        alt: 'Preloved Electronics' },
  { src: '/images/logos/Hornbaek-Deluxe-125x70-1.webp', alt: 'Hornbæk Deluxe Beauty & Wellness' },
  { src: '/images/logos/NU-125x70-1.webp',              alt: 'NÜ Denmark' },
];
---

<section class="py-12 bg-white border-y border-gray-100 overflow-hidden">
  <div class="relative">
    <div aria-hidden="true" class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div aria-hidden="true" class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <div class="flex items-center gap-24 marquee">
      {[...logos, ...logos].map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          width="125"
          height="70"
          class="shrink-0 h-16 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .marquee {
    animation: marquee 36s linear infinite;
    width: max-content;
  }

  .marquee:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee { animation: none; }
  }
</style>
