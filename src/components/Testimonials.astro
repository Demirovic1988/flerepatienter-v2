---
// Per-logo dimensioner tuned så de optisk fylder samme mængde i den hvide chip
// (kompenserer for at hvert logo har forskelligt aspect-ratio)
const cases = [
  {
    eyebrow: 'Poul Staal Klinikkerne · 4 klinikker',
    title: 'Fra fragmenteret online tilstedeværelse til ét samlet flow.',
    body:
      'Jeg overtog markedsføringen for fire klinikker under Poul Staal, byggede et nyt design og en samlet kunderejse fra annonce til booking. I dag kommer der et stabilt flow af de rigtige patienter — ikke prisshoppere, men dem klinikkerne faktisk vil have i stolen.',
    logo: '/images/logos/Hafniahus.webp',
    logoAlt: 'Hafniahus Tandlægerne',
    logoStyle: 'height: 52px; max-width: 220px;',
  },
  {
    eyebrow: 'Tandhuset Odder',
    title: 'Fra usynlig på Google til markant lokal placering.',
    body:
      'Tandhuset Odder var en stærk klinik — men nye patienter fandt dem ikke online. Efter overtagelsen er den lokale organiske trafik vokset markant, og klinikken rangerer nu højt på de søgninger der faktisk fører til bookinger — ikke kun "tandlæge Odder", men også behandlingerne lokalkonkurrenterne kæmper om.',
    logo: '/images/logos/Tandhuset-Odder.png',
    logoAlt: 'Tandhuset Odder',
    logoStyle: 'height: 64px; max-width: 200px;',
  },
  {
    eyebrow: 'Tandlægerne Banegårdspladsen · smildubare.dk',
    title: 'Ud af 60-måneders kontrakten — ind i resultater.',
    body:
      'Klinikken var låst i en 60-måneders kontrakt med deres tidligere bureau uden at se reel værdi. Jeg overtog konceptet, fik dem fri af bindingerne og byggede en marketing-motor de selv ejer — uden lange aftaler, kun målbart resultat.',
    logo: '/images/logos/Tandlaegerne-Banegaardspladsen.png',
    logoAlt: 'Tandlægerne Banegårdspladsen',
    logoStyle: 'height: 48px; max-width: 220px;',
  },
];
---

<section id="cases" class="py-24 md:py-32 bg-paper">
  <div class="max-w-6xl mx-auto px-5">

    <!-- Header -->
    <div class="max-w-2xl mb-14 md:mb-16">
      <p class="reveal eyebrow mb-4">Sådan ser et forløb ud</p>
      <h2 class="reveal reveal-delay-1 text-4xl md:text-5xl font-medium mb-5 tracking-tight">
        Tre klinikker. Tre huller. <span class="accent">Samme metode.</span>
      </h2>
      <p class="reveal reveal-delay-2 text-lg text-ash leading-relaxed">
        Jeg taler ikke om abstrakte case studies. Det her er konkrete forløb,
        hvor jeg har overtaget rodet og bygget noget der virker.
      </p>
    </div>

    <!-- Cases -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-7">
      {cases.map((c, i) => (
        <article class={`reveal reveal-delay-${i + 1} bg-ink rounded-lg p-8 md:p-10 text-white flex flex-col`}>

          <div class="text-orange text-[11px] font-semibold tracking-[0.18em] uppercase mb-6" style="font-family: var(--font-sans);">
            {c.eyebrow}
          </div>

          <h3 class="text-2xl md:text-[28px] font-medium text-white mb-5 leading-snug tracking-tight" style="font-family: var(--font-display);">
            {c.title}
          </h3>

          <p class="text-white/75 text-[15px] leading-relaxed mb-8 flex-1" style="font-family: var(--font-sans);">
            {c.body}
          </p>

          <!-- Logo-chip — ens dimensioner på tværs af alle kort, optisk balancerede logoer indenfor -->
          <div class="pt-8 border-t border-white/10">
            <div class="bg-white rounded-md w-full h-24 flex items-center justify-center px-6" style="box-shadow: 0 1px 2px rgba(0,0,0,0.15);">
              <img
                src={c.logo}
                alt={c.logoAlt}
                style={c.logoStyle}
                class="block w-auto object-contain"
                loading="lazy"
              />
            </div>
          </div>

        </article>
      ))}
    </div>

  </div>
</section>
