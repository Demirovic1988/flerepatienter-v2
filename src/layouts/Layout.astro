---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Flerepatienter.dk – Vi finder hullerne i din markedsføring',
  description = 'Vi hjælper danske tandklinikker med at få flere patienter — ikke ved at producere mere marketing, men ved at finde og lukke hullerne i den, de allerede har.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://flerepatienter.dk').href;
const ogImage = new URL('/og-image.png', 'https://flerepatienter.dk').href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Flerepatienter.dk',
  description: 'Markedsføring for tandklinikker. Vi finder hullerne mellem klik og booking.',
  url: canonicalURL,
  telephone: '+4581530540',
  email: 'jatak@flerepatienter.dk',
  founder: {
    '@type': 'Person',
    name: 'Elvis Demirovic',
  },
  areaServed: 'DK',
  inLanguage: 'da',
  serviceType: 'Tandlæge markedsføring',
};
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#D4621A" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="da_DK" />
    <meta property="og:site_name" content="Flerepatienter.dk" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Flerepatienter.dk — Vi finder hullerne i din markedsføring" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Brandbook §04: Playfair Display (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Tracking (kun ved cookie-samtykke) -->
    <script>
      function loadTracking() {
        const ga = document.createElement('script');
        ga.async = true;
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-G3L4LZCEP5';
        document.head.appendChild(ga);
        (window as any).dataLayer = (window as any).dataLayer || [];
        function gtag(...args: any[]) { (window as any).dataLayer.push(args); }
        gtag('js', new Date());
        gtag('config', 'G-G3L4LZCEP5');

        (function(f: any, b: Document, e: string, v: string) {
          if (f.fbq) return;
          const n: any = f.fbq = function() { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
          if (!f._fbq) f._fbq = n;
          n.push = n; n.loaded = true; n.version = '2.0'; n.queue = [];
          const t = b.createElement(e) as HTMLScriptElement;
          t.async = true; t.src = v;
          b.head.appendChild(t);
        })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
        (window as any).fbq('init', '1543349950714721');
        (window as any).fbq('track', 'PageView');
      }

      if (localStorage.getItem('cookie_consent') === 'accepted') {
        loadTracking();
      }

      (window as any).__loadTracking = loadTracking;
    </script>
  </head>
  <body>
    <slot />

    <!-- Cookie banner — Ink baggrund, Patient Orange CTA -->
    <div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999; padding:1.25rem 1.5rem; background:#1A1A1A; border-top:1px solid rgba(255,255,255,0.08);">
      <div style="max-width:72rem; margin:0 auto; display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:1rem;">
        <p style="color:rgba(255,255,255,0.78); font-size:0.9rem; margin:0; max-width:620px; line-height:1.55; font-family: 'Inter', sans-serif;">
          Vi bruger cookies til statistik og markedsføring for at forbedre din oplevelse.
          Læs mere i vores <a href="/privatlivspolitik" style="color:#D4621A; text-decoration:underline; text-underline-offset:3px;">privatlivspolitik</a>.
        </p>
        <div style="display:flex; gap:0.75rem; flex-shrink:0;">
          <button id="cookie-decline" style="background:transparent; border:1px solid rgba(255,255,255,0.22); color:rgba(255,255,255,0.7); font-family:'Inter',sans-serif; font-size:0.875rem; font-weight:600; padding:0.65rem 1.25rem; border-radius:4px; cursor:pointer;">
            Kun nødvendige
          </button>
          <button id="cookie-accept" style="background:#D4621A; border:1px solid #D4621A; color:#fff; font-family:'Inter',sans-serif; font-size:0.875rem; font-weight:600; padding:0.65rem 1.5rem; border-radius:4px; cursor:pointer;">
            Acceptér alle
          </button>
        </div>
      </div>
    </div>

    <script>
      const banner = document.getElementById('cookie-banner');
      const consent = localStorage.getItem('cookie_consent');
      if (!consent && banner) banner.style.display = 'block';

      document.getElementById('cookie-accept')?.addEventListener('click', () => {
        localStorage.setItem('cookie_consent', 'accepted');
        if (banner) banner.style.display = 'none';
        (window as any).__loadTracking?.();
      });

      document.getElementById('cookie-decline')?.addEventListener('click', () => {
        localStorage.setItem('cookie_consent', 'declined');
        if (banner) banner.style.display = 'none';
      });
    </script>

    <!-- Scroll reveal -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
