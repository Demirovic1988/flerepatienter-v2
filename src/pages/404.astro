---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Siden blev ikke fundet (404) – Flerepatienter.dk"
  description="Den side du leder efter findes ikke. Gå tilbage til forsiden."
>
  <Header />

  <main class="bg-paper relative overflow-hidden min-h-screen">

    <!-- Diskrete brand-cirkler (jf. hero) -->
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 right-0 w-[560px] h-[560px] rounded-full bg-cream/60 blur-3xl translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-[380px] h-[380px] rounded-full bg-bone blur-3xl -translate-x-1/4 translate-y-1/3"></div>
    </div>

    <div class="error-content max-w-3xl mx-auto px-5 relative z-10 text-center">

      <p class="eyebrow mb-6">Fejl 404</p>

      <p class="text-7xl md:text-9xl text-orange italic mb-6 leading-none"
         style="font-family: var(--font-display); font-weight: 500;">
        404
      </p>

      <h1 class="text-4xl md:text-5xl font-medium mb-5 tracking-tight">
        Her fandt vi et <span class="accent">hul.</span>
      </h1>

      <p class="text-lg text-ash leading-relaxed mb-10 max-w-xl mx-auto">
        Den side du leder efter findes ikke — eller er flyttet. Lad os få dig
        tilbage på sporet.
      </p>

      <div class="flex flex-col sm:flex-row sm:items-center justify-center gap-4">
        <a href="/" class="btn btn-primary text-base px-7 py-4">
          Tilbage til forsiden
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/#kontakt" class="btn btn-secondary text-base px-7 py-4">
          Kontakt os
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* 150px luft fra den faste menu (header er 64px på mobil / 72px på desktop) */
  .error-content {
    padding-top: 214px;
    padding-bottom: 6rem;
  }
  @media (min-width: 768px) {
    .error-content {
      padding-top: 222px;
      padding-bottom: 9rem;
    }
  }
</style>
