---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';
---

<Layout
  title="De 3 huller – Flerepatienter.dk"
  description="Se hvordan de fleste tandklinikker mister patienter, de allerede har betalt for – og hvad du kan gøre ved det."
>
  <Header />

  <main style="padding-top: 90px;">

    <!-- Intro -->
    <section class="py-16 bg-gradient-to-br from-[#FFF7F0] via-[#F8FAFC] to-white">
      <div class="max-w-6xl mx-auto px-5 text-center">
        <span class="inline-block bg-[#FFF7F0] text-[#F97316] text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded-full mb-5">
          Gratis video
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-navy mb-4 leading-tight">
          De fleste tandklinikker mister patienter,<br class="hidden md:block" />
          <span class="text-[#F97316]">de allerede har betalt for</span>
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto mb-2">
          3 fejl der får potentielle patienter til at vælge en anden klinik
        </p>
      </div>
    </section>

    <!-- Video embed -->
    <section class="bg-[#F8FAFC] py-10">
      <div class="max-w-4xl mx-auto px-5">
        <div class="rounded-2xl overflow-hidden shadow-2xl bg-navy" style="position: relative; padding-top: 56.25%;">
          <iframe
            src="https://flerepatienter.dk/de-3-huller/"
            title="De 3 huller – VSL"
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white text-center">
      <div class="max-w-xl mx-auto px-5">
        <p class="text-lg text-muted mb-8">
          Klar til at lukke hullerne og få flere bookinger?
        </p>
        <a
          href={CALENDLY}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#F97316] hover:bg-[#ea6c0a] text-white font-bold text-lg px-10 py-5 rounded-full transition-all duration-200 shadow-xl shadow-[#F97316]/25 hover:-translate-y-0.5"
        >
          Book gratis samtale – helt uforpligtende
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <p class="mt-4 text-muted text-sm">Svar inden for 24 timer · Ingen binding</p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
