---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';
---

<Layout
  title="De 3 huller – Flerepatienter.dk"
  description="Se de 3 fejl der får potentielle patienter til at vælge en anden klinik – og hvordan du lukker hullerne i din kunderejse."
>
  <Header />

  <main style="padding-top: 90px;">

    <!-- Hero tekst -->
    <section class="py-16 bg-gradient-to-br from-[#FFF7F0] via-[#F8FAFC] to-white">
      <div class="max-w-4xl mx-auto px-5 text-center">

        <span class="inline-block bg-[#FFF7F0] text-[#F97316] text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded-full mb-6">
          Gratis video
        </span>

        <h1 class="text-4xl md:text-5xl font-extrabold text-navy mb-5 leading-tight">
          De fleste tandklinikker mister patienter,<br class="hidden md:block" />
          <span class="text-[#F97316]">de allerede har betalt for</span>
        </h1>

        <p class="text-xl text-muted max-w-2xl mx-auto leading-relaxed">
          Se de 3 fejl der får potentielle patienter til at vælge en anden klinik –
          og hvordan du lukker hullerne i din kunderejse.
        </p>

      </div>
    </section>

    <!-- Video + CTA -->
    <section class="bg-[#F8FAFC] py-12 pb-24">
      <div class="max-w-4xl mx-auto px-5">
        <!-- VIDEO EMBED HERUNDER — indsæt din Wistia/Vimeo/YouTube kode -->
        <div class="rounded-2xl overflow-hidden shadow-2xl" style="position: relative; padding-top: 56.25%; background: #0D1F3C;">
          <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 1rem;">
            <div style="width: 72px; height: 72px; background: #F97316; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
            </div>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.9rem;">Video indlæses…</p>
          </div>
        </div>
        <!-- VIDEO EMBED SLUT -->

        <div class="mt-14 text-center">
          <a
            href="https://form.bunica.dk"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center bg-[#F97316] hover:bg-[#ea6c0a] text-white font-bold text-lg px-10 py-5 rounded-2xl transition-all duration-200 shadow-xl shadow-[#F97316]/25 hover:-translate-y-0.5 w-full max-w-xl"
          >
            Besvar 5 spørgsmål og se, hvordan du kan få flere bookinger
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
