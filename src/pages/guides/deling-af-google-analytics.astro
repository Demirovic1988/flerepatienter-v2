---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

const CALENDLY = 'https://calendly.com/jatak-flerepatienter/30min';
const PHONE = '+45 81 530 540';
const PHONE_HREF = 'tel:+4581530540';
const EMAIL = 'marketing@flerepatienter.dk';

const sections = [
  {
    title: 'Opret Google Analytics',
    steps: [
      {
        id: 'log-ind-opret',
        title: 'Log ind på Google Analytics',
        body: 'Gå til analytics.google.com og log ind med jeres Google-konto. Hvis I allerede har en konto, kan I springe direkte til afsnittet "Adgang til Google Analytics".',
        link: { label: 'analytics.google.com', href: 'https://analytics.google.com' },
      },
      {
        id: 'start-opsaetningen',
        title: 'Start opsætningen af en ny konto',
        body: 'Klik på Admin (tandhjul-ikonet) nederst til venstre, og vælg "Create" → "Account" for at starte opsætningen.',
        placeholder: true,
      },
      {
        id: 'indtast-oplysninger',
        title: 'Indtast oplysninger om kontoen',
        body: 'Giv kontoen et navn (typisk virksomhedens navn) og vælg, hvilke data Google må dele med deres øvrige services.',
        placeholder: true,
      },
      {
        id: 'navngiv-property',
        title: 'Navngiv din property',
        body: 'Opret en property under kontoen. Navngiv den, så I let kan skelne mellem flere websites eller apps senere.',
        placeholder: true,
      },
      {
        id: 'land-og-valuta',
        title: 'Vælg land og valuta',
        body: 'Angiv jeres lands tidszone og den valuta, I bruger til at tracke konverteringsværdier.',
        placeholder: true,
      },
      {
        id: 'branche',
        title: 'Angiv branche og virksomhedsstørrelse',
        body: 'Vælg den branche, der bedst beskriver jeres virksomhed, samt jeres størrelseskategori. Det bruges af Google til standardrapporter.',
        placeholder: true,
      },
      {
        id: 'maal',
        title: 'Vælg virksomhedens mål',
        body: 'Markér de mål, der er vigtigst for jer (fx leads, online-salg, brandbevidsthed). Det styrer, hvilke rapporter Google fremhæver.',
        placeholder: true,
      },
      {
        id: 'accepter-vilkaar',
        title: 'Accepter Googles vilkår',
        body: 'Læs og accepter Googles servicevilkår og databehandleraftalen for Google Analytics.',
        placeholder: true,
      },
      {
        id: 'platform',
        title: 'Vælg platform for dataindsamling',
        body: 'Vælg "Web" som datakilde. Indtast jeres domæne (fx flerepatienter.dk) og giv datastrømmen et navn.',
        placeholder: true,
      },
      {
        id: 'datastream',
        title: 'Opret din datastream',
        body: 'Når datastrømmen er oprettet, modtager I et Measurement ID (G-XXXXXXX), som skal sættes ind i jeres website — fx via Google Tag Manager eller direkte i koden.',
        placeholder: true,
      },
    ],
  },
  {
    title: 'Adgang til Google Analytics',
    steps: [
      {
        id: 'log-ind-analytics',
        title: 'Log ind i Analytics',
        body: 'Gå til analytics.google.com/analytics/web og log ind på den konto, hvor din property er oprettet.',
        link: { label: 'analytics.google.com/analytics/web', href: 'https://analytics.google.com/analytics/web' },
      },
      {
        id: 'admin-panel',
        title: 'Åbn administrationspanelet',
        body: 'Klik på Administrator nederst i venstre side. Her finder du alle indstillinger for konto, property og brugeradgang.',
        placeholder: true,
      },
      {
        id: 'brugeradministration',
        title: 'Gå til brugeradministration',
        body: 'Under konto- eller propertyniveau finder du menuen Access Management eller Brugeradministration. Her kan du se og administrere, hvem der har adgang til Analytics.',
        placeholder: true,
      },
      {
        id: 'tilfoej-bruger',
        title: 'Tilføj en ny bruger',
        body: 'Klik på Add users eller Tilføj bruger. Her kan du invitere nye brugere til kontoen.',
        placeholder: true,
      },
      {
        id: 'opret-adgang-flerepatienter',
        title: 'Opret adgang til FLEREPATIENTER',
        body: 'Indtast vores mailadresse i feltet. Vælg den rette rolle, som oftest er Editor, så vi kan opsætte målinger og analysere data.',
        placeholder: true,
        emailLink: true,
      },
      {
        id: 'gem-send',
        title: 'Gem og send invitationen',
        body: 'Klik på Add for at tilføje brugeren. Herefter får vi adgang til kontoen og kan hjælpe med opsætning, analyse og optimering af jeres data.',
      },
    ],
  },
];

let counter = 0;
const numberedSections = sections.map((section) => ({
  ...section,
  steps: section.steps.map((step) => ({ ...step, number: ++counter })),
}));
const totalSteps = counter;
---

<Layout
  title="Deling af Google Analytics adgang | Flerepatienter"
  description="Trin-for-trin guide til at oprette Google Analytics og give Flerepatienter adgang til jeres property."
>
  <main class="bg-paper">

    <section class="pt-28 pb-10 md:pt-36 md:pb-14 border-b border-line">
      <div class="max-w-6xl mx-auto px-5">

        <nav aria-label="Brødkrumme" class="mb-7" style="font-family: var(--font-sans);">
          <ol class="flex flex-wrap items-center gap-2 text-sm text-ash">
            <li><a href="/guides/" class="hover:text-orange transition-colors">Guides</a></li>
            <li aria-hidden="true" class="text-line">/</li>
            <li class="text-ink font-medium" aria-current="page">Deling af Google Analytics adgang</li>
          </ol>
        </nav>

        <div class="max-w-3xl">
          <p class="eyebrow mb-5">Google Analytics · Opsætning &amp; Adgang</p>
          <h1 class="text-4xl sm:text-5xl md:text-[56px] font-medium tracking-tight leading-[1.05]">
            Deling af <span class="accent">Google Analytics</span> adgang
          </h1>
          <p class="mt-5 text-base text-ash" style="font-family: var(--font-sans);">
            Estimeret læsetid: ca. 4 min · {totalSteps} trin
          </p>
        </div>
      </div>
    </section>

    <section class="py-14 md:py-20">
      <div class="max-w-6xl mx-auto px-5 grid gap-10 md:grid-cols-[320px_minmax(0,1fr)] md:gap-12">

        <aside class="md:sticky md:top-28 md:self-start">
          <nav
            aria-label="Indholdsfortegnelse"
            class="toc-card rounded-2xl bg-ink text-white px-6 py-7 md:px-7 md:py-8 relative overflow-hidden"
          >
            <div class="space-y-6 relative z-10" style="font-family: var(--font-sans);">
              {numberedSections.map((section) => (
                <div>
                  <p class="toc-section text-white font-semibold mb-3 text-[14px] tracking-tight">{section.title}</p>
                  <ol class="space-y-3">
                    {section.steps.map((s) => (
                      <li>
                        <a
                          href={`#${s.id}`}
                          data-toc-link={s.id}
                          class="toc-link block text-[15px] leading-snug text-white/55 hover:text-white transition-colors"
                        >
                          <span class="toc-num">{s.number}.</span>{' '}
                          <span class="toc-label">{s.title}</span>
                        </a>
                      </li>
                    ))}
                  </ol>
                </div>
              ))}
            </div>
          </nav>
        </aside>

        <article>

          <section class="mb-10">
            <h2 class="text-3xl md:text-[40px] font-medium mb-5 tracking-tight leading-[1.1]">
              Deling af Google Analytics
            </h2>
            <p class="text-lg text-ash leading-relaxed max-w-2xl">
              Guiden her viser, hvordan I opretter Google Analytics fra bunden — og
              hvordan I bagefter giver Flerepatienter adgang til jeres property, så
              vi kan opsætte konverteringer, måling og rapporter.
            </p>
          </section>

          {numberedSections.map((section) => (
            <div class="mb-10">
              <h2 class="text-[26px] md:text-3xl font-medium tracking-tight mb-6">{section.title}</h2>
              <ol class="space-y-6">
                {section.steps.map((s) => (
                  <li
                    id={s.id}
                    class="scroll-mt-28 rounded-2xl bg-bone/70 border border-line px-6 py-7 md:px-9 md:py-9"
                  >
                    <h3 class="text-2xl md:text-[28px] font-medium tracking-tight leading-snug mb-4">
                      {s.number}. {s.title}
                    </h3>

                    <p class="text-ink/85 leading-relaxed max-w-prose">
                      {s.body}
                      {s.link && (
                        <>
                          {' '}
                          <a href={s.link.href} target="_blank" rel="noopener noreferrer" class="text-orange font-semibold underline underline-offset-4 decoration-2">
                            {s.link.label}
                          </a>
                        </>
                      )}
                    </p>

                    {s.emailLink && (
                      <div class="mt-5 rounded-md border border-orange/30 bg-cream/40 px-5 py-4 flex items-center justify-between gap-4 flex-wrap">
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-orange mb-1.5" style="font-family: var(--font-sans);">E-mail</p>
                          <code class="block text-lg font-semibold text-ink select-all" style="font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;">
                            {EMAIL}
                          </code>
                        </div>
                        <button
                          type="button"
                          class="copy-btn inline-flex items-center gap-2 rounded-md bg-orange text-white px-4 py-2 text-sm font-semibold hover:bg-orange-deep transition-colors"
                          style="font-family: var(--font-sans);"
                          data-copy-value={EMAIL}
                          aria-label="Kopiér e-mail"
                        >
                          <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                          </svg>
                          <svg class="icon-check hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                          <span class="copy-label">Kopiér</span>
                        </button>
                      </div>
                    )}

                    {s.placeholder && (
                      <figure class="mt-6">
                        <div
                          class="w-full aspect-[16/9] rounded-lg border border-line bg-bone flex items-center justify-center text-ash text-sm"
                          style="font-family: var(--font-sans);"
                          role="img"
                          aria-label={`Billede ${s.number} – Skærmbillede uploades`}
                        >
                          <span>Billede {s.number} – Skærmbillede uploades</span>
                        </div>
                      </figure>
                    )}
                  </li>
                ))}
              </ol>
            </div>
          ))}

        </article>
      </div>
    </section>

    <section class="bg-ink py-24 md:py-32 relative overflow-hidden">
      <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[480px] h-[480px] rounded-full bg-orange/10 blur-3xl translate-x-1/3 -translate-y-1/4"></div>
        <div class="absolute bottom-0 left-0 w-[360px] h-[360px] rounded-full bg-orange/5 blur-3xl -translate-x-1/4 translate-y-1/4"></div>
      </div>

      <div class="max-w-3xl mx-auto px-5 relative z-10 text-center">
        <p class="eyebrow mb-6" style="color: #E8915B;">Næste skridt</p>
        <h2 class="text-4xl md:text-5xl font-medium text-white mb-6 tracking-tight leading-[1.05]">
          Klar til <span class="accent" style="color: #E8915B;">flere patienter?</span>
        </h2>
        <p class="text-white/75 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
          Book et gratis strategiopkald, så kigger vi på hullerne i jeres
          markedsføring og patientrejse.
        </p>

        <div class="flex justify-center mb-12">
          <a
            href={CALENDLY}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary text-base px-8 py-4"
          >
            Book gratis strategiopkald
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
          <a
            href={PHONE_HREF}
            class="group flex items-center gap-4 bg-white/[0.04] hover:bg-white/[0.08] border border-white/10 hover:border-orange/40 rounded-lg px-5 py-4 text-left transition-all duration-200"
            aria-label={`Ring til ${PHONE}`}
          >
            <div class="w-10 h-10 rounded bg-orange/15 flex items-center justify-center shrink-0 group-hover:bg-orange/25 transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D4621A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.12 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.37a16 16 0 0 0 5.72 5.72l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <div class="text-white/50 text-[11px] font-semibold uppercase tracking-[0.15em] mb-0.5" style="font-family: var(--font-sans);">Telefon</div>
              <div class="text-white font-semibold text-[15px]" style="font-family: var(--font-sans);">{PHONE}</div>
            </div>
          </a>

          <a
            href={`mailto:${EMAIL}`}
            class="group flex items-center gap-4 bg-white/[0.04] hover:bg-white/[0.08] border border-white/10 hover:border-orange/40 rounded-lg px-5 py-4 text-left transition-all duration-200"
            aria-label={`Send email til ${EMAIL}`}
          >
            <div class="w-10 h-10 rounded bg-orange/15 flex items-center justify-center shrink-0 group-hover:bg-orange/25 transition-colors">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D4621A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="text-white/50 text-[11px] font-semibold uppercase tracking-[0.15em] mb-0.5" style="font-family: var(--font-sans);">E-mail</div>
              <div class="text-white font-semibold text-[15px]" style="font-family: var(--font-sans);">{EMAIL}</div>
            </div>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .toc-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 0%, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0) 45%),
      radial-gradient(circle at 95% 100%, rgba(212,98,26,0.07) 0%, rgba(212,98,26,0) 60%);
    pointer-events: none;
  }

  .toc-num {
    color: rgba(255,255,255,0.45);
    font-weight: 500;
    margin-right: 0.15rem;
    transition: color 200ms ease;
  }

  .toc-link:hover .toc-num,
  .toc-link.is-active .toc-num {
    color: #E8915B;
  }

  .toc-link.is-active {
    color: #fff;
    font-weight: 600;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const ids = Array.from(links).map((a) => a.dataset.tocLink!).filter(Boolean);
  const sections = ids
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  const setActive = (id: string | null) => {
    links.forEach((a) => {
      a.classList.toggle('is-active', a.dataset.tocLink === id);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
      if (visible) setActive(visible.target.id);
    },
    { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
  );

  sections.forEach((s) => observer.observe(s));

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const value = btn.dataset.copyValue ?? '';
      try {
        await navigator.clipboard.writeText(value);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = value;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      const iconCopy = btn.querySelector('.icon-copy');
      const iconCheck = btn.querySelector('.icon-check');
      const label = btn.querySelector('.copy-label');
      iconCopy?.classList.add('hidden');
      iconCheck?.classList.remove('hidden');
      if (label) label.textContent = 'Kopieret';
      setTimeout(() => {
        iconCopy?.classList.remove('hidden');
        iconCheck?.classList.add('hidden');
        if (label) label.textContent = 'Kopiér';
      }, 1800);
    });
  });
</script>
